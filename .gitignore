# --- Python ----------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
.eggs/
build/
dist/
develop-eggs/
sdist/
parts/
var/
wheels/
.installed.cfg
pip-log.txt
pip-delete-this-directory.txt

# --- Virtualenvs -----------------------------------------------------------
venv/
.venv/
env/
ENV/

# --- Django ----------------------------------------------------------------
*.log
*.pot
*.mo
db.sqlite3
db.sqlite3-journal
local_settings.py
staticfiles/
media/

# --- Velour secrets (per the secret-file protocol) -------------------------
secret_key.txt
health_token.txt
mail_relay_token.txt
provisioning_secret.txt
*.token
# LLM provider API keys — per-provider chmod-600 files
llm_*.key
*_api_key.txt
# PlatformIO per-device secrets (API tokens for the ESP fleet)
gary_test/secrets.ini

# --- Local-only docs / scratch the user doesn't want in the public repo ----
Master_Control_Notes.pdf

# --- Skyfield ephemeris (auto-downloaded on first use, ~17MB) -------------
chronos/data/*.bsp

# --- Piper TTS voice models (each ~60MB, installed per-machine) ----------
lingua/data/piper_voices/*.onnx
lingua/data/piper_voices/*.onnx.json

# --- Backups, caches, scratch ---------------------------------------------
# Ignore actual snapshots, NOT the Django app code.
backups/snapshots/
backups/*.tar
backups/*.tar.gz
.cache/
.coverage
.tox/
.pytest_cache/
htmlcov/

# --- Editors / OS ----------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Claude harness state (machine-local, not source) ---------------------
.claude/
memory/
/oracle/models_dir/*.tree.json

# --- Per-app outputs (binaries, ckpts, scratch experiments) ---------------
# Add new /outputs/<app>/ entries below per subdir (NOT a blanket /outputs/*)
# so that some output kinds can still be promoted to the public repo case
# by case. The canonical .c sources for the Casting app live under
# static/casting/sources/ and are tracked normally.
/outputs/casting/

# --- Runtime state written by smart_runserver -----------------------------
# Overwritten every server start with whichever port from PREFERRED_PORTS
# was actually free. Nothing in the codebase reads it as configuration.
velour_port.txt

# --- App Factory clone-time customization ---------------------------------
# Written by /apps/create/ at the root of a fresh clone tree, consumed by
# `manage.py apply_clone_init` on first boot. Both the live and the
# .applied form should stay local to each install, never tracked.
clone_init.json
clone_init.json.applied

# --- Isolation oneclick-hex-class4 compiled hunter (keep .c + .py source) -
/isolation/artifacts/oneclick_class4/hunter
/isolation/artifacts/oneclick_class4/winner_*
