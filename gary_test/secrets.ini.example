; secrets.ini.example — copy to secrets.ini and fill in real tokens.
;
; Each [secrets_name] section provides the NODE_TOKEN build flag for
; the corresponding [env:name] in platformio.ini. The token is the
; 48-char string from the Node's detail page in Velour.
;
; This file is gitignored — secrets.ini never leaves your machine.

[secrets_gary]
build_flags = '-DNODE_TOKEN="PASTE_48_CHAR_TOKEN_HERE"'

[secrets_larry]
build_flags = '-DNODE_TOKEN="PASTE_48_CHAR_TOKEN_HERE"'

[secrets_terry]
build_flags = '-DNODE_TOKEN="PASTE_48_CHAR_TOKEN_HERE"'
