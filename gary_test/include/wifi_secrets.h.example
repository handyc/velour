// Copy this file to `wifi_secrets.h` in the same directory and fill in
// the four values below before building. The real wifi_secrets.h is
// gitignored — it never leaves your machine.

#pragma once

// Your Wi-Fi network credentials. The network must be 2.4 GHz —
// ESP8266 does not support 5 GHz.
#define WIFI_SSID     "your-wifi-name"
#define WIFI_PASSWORD "your-wifi-password"

// The base URL of your Velour instance, reachable from Gary's network
// position. Examples:
//   "http://192.168.1.50:7777"   <- LAN dev (use the LAN IP, NOT 127.0.0.1)
//   "https://velour.lucdh.nl"    <- production behind nginx
// NO trailing slash. NO /api/nodes path. The client appends those.
#define VELOUR_URL    "http://192.168.1.50:7777"

// The API token for the Gary node. Find it at /nodes/gary/ in the
// Velour Fleet UI. It's a 48-character alphanumeric string.
#define NODE_TOKEN    "PASTE_THE_48_CHAR_GARY_TOKEN_HERE"

// The slug Velour knows Gary by. If you renamed Gary in the Fleet UI,
// change this to match. Default is "gary".
#define NODE_SLUG     "gary"

// Optional: port the on-device web server listens on. Defaults to 80 if
// not set. Use a unique port per device in your fleet if you plan to
// reverse-proxy them through a front-end Velour — e.g. Gary on 80,
// Larry on 8000, Moe on 8001, and so on.
// #define NODE_HTTP_PORT 8000
