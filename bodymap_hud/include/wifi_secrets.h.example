// Copy to include/wifi_secrets.h — that path is gitignored. Matches the
// bodymap_firmware + gary_test convention so the same secrets workflow
// applies across fleets.

#pragma once

#define WIFI_SSID              "your-ssid"
#define WIFI_PASSWORD          "your-password"

// Base URL of the Velour instance this HUD talks to. No trailing slash,
// no /api path — VelourClient appends those.
#define VELOUR_BASE_URL        "http://velour.example.com"

// Shared provisioning secret from Velour settings. Only needed for the
// first boot — after that the node has its own per-device api_token
// persisted to LittleFS.
#define VELOUR_PROVISIONING_SECRET "paste-secret-from-settings-page"
