// Copy this file to include/wifi_secrets.h and fill in real values.
// wifi_secrets.h is gitignored so your WiFi password + provisioning
// secret don't leak.
//
// Every bodymap node flashes the SAME firmware with the SAME file —
// per-node identity comes from the MAC-based registerSelf() call at boot.

#pragma once

// WiFi station credentials — the network bodymap nodes join at boot.
#define WIFI_SSID     "YourWiFiNetwork"
#define WIFI_PASSWORD "YourWiFiPassword"

// Base URL of the Velour deployment that owns this fleet. Must include
// scheme and port if non-standard, no trailing slash.
#define VELOUR_BASE_URL "http://velour.lucdh.nl"

// Shared provisioning secret. Must match settings.VELOUR_PROVISIONING_SECRET
// on the Velour server. Bodymap nodes present this when calling
// /api/nodes/register so the server knows they're legit fleet members.
//
// NOTE (2026-04-17): the /register endpoint is implemented on branch
// mac-self-registration in the Velour repo but not yet merged to main
// or deployed. First-boot registerSelf() will fail until that branch
// ships. Stored credentials path still works for subsequent boots.
#define VELOUR_PROVISIONING_SECRET "replace-me-with-real-secret"
